@baseUrl = http://localhost:8888
@email = test@manan.cloud
@otp = 620968
@accessToken = paste_jwt_here

### Root health
GET {{baseUrl}}/

### Request OTP (sends code to email)
POST {{baseUrl}}/auth/request-otp
Content-Type: application/json

{
  "email": "{{email}}"
}

### Verify OTP (replace @otp with the code you received)
# @name verifyOtp
POST {{baseUrl}}/auth/verify-otp
Content-Type: application/json

{
  "email": "{{email}}",
  "otp": "{{otp}}"
}

### Save token from verify response (run right after verifyOtp)
> {%
  if (response.body && response.body.access_token) {
    client.global.set("accessToken", response.body.access_token);
  }
%}

### Get current user using token from verify
GET {{baseUrl}}/auth/me
Authorization: Bearer {{accessToken}}

### Invalid OTP example (should return 401)
POST {{baseUrl}}/auth/verify-otp
Content-Type: application/json

{
  "email": "{{email}}",
  "otp": "111111"
}

### Rate limit smoke test (run a few times quickly to trigger 429)
POST {{baseUrl}}/auth/request-otp
Content-Type: application/json

{
  "email": "{{email}}"
}
